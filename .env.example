# Runtime storage and limits.
MEDIA_TMP_DIR=/tmp/webbrain-webtools
MEDIA_TTL_SECONDS=1800
MAX_CONCURRENT_DOWNLOADS=2
MAX_DOWNLOAD_MB=512
DEFAULT_MAX_HEIGHT=720

# Optional cookie files for platforms that need logged-in cookies.
# Mount or create files under ./cookies, for example cookies/youtube.txt.
YTDLP_COOKIES_DIR=/cookies

# Recommended for YouTube transcripts on cloud hosts like DigitalOcean.
# Use the base Webshare username without the trailing "-rotate".
# Set both WEBSHARE_PROXY_USERNAME and WEBSHARE_PROXY_PASSWORD together.
# Example username: ervyombx
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
WEBSHARE_FILTER_IP_LOCATIONS=
WEBSHARE_RETRIES_WHEN_BLOCKED=10
WEBSHARE_DOMAIN_NAME=p.webshare.io
WEBSHARE_PROXY_PORT=80

# Generic fallback for transcript requests if not using Webshare.
TRANSCRIPT_PROXY_HTTP_URL=
TRANSCRIPT_PROXY_HTTPS_URL=

# Optional proxy for yt-dlp media resolve/download.
YTDLP_PROXY_URL=
